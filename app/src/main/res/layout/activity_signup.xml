<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Signup">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Signup"
        android:textSize="30sp"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#A91B4B"/>

<!--    below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

<!--            below is the edt text for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter your username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#DC3D72"
                android:padding="10dp"/>

            <!--            below is the edt text for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your email address"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:background="#DC3D72"
                android:padding="10dp"/>

            <!--            below is the edt text for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#DC3D72"
                android:padding="10dp"/>

            <!--            below is the edt text for phonenumber-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter your phone number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#DC3D72"
                android:padding="10dp"/>

<!--            below is a sgnup button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="25dp"
                android:textColor="#E1CDD8"
                android:backgroundTint="#051232"
                android:id="@+id/signupBtn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already Have an Accout? Signin"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#0013e9"
                android:id="@+id/signintxt" />




        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>