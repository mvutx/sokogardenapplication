<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Signin"
    android:background="#00BCD4">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️ Signin"
        android:textSize="47sp"
        android:fontFamily="cursive"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#E0CDD4"/>

<!--    below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:padding="10dp">
<!--        below is a linear layout that shall align contents vertically-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#763C50">

<!--            below is the email edittext-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your Email Address"
                android:textColorHint="#000"
                android:id="@+id/email"
                android:textColor="#000"
                android:layout_margin="8dp"
                android:background="#D77697"
                android:padding="11dp"/>
<!--            below is the password edittext-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your password"
                android:textColorHint="#000"
                android:id="@+id/password"
                android:textColor="#000"
                android:layout_margin="8dp"
                android:background="#D77697"
                android:padding="11dp"/>
<!--            below is a signin button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" 👮🏽 Signin"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="30dp"
                android:textColor="#FFEB3B"
                android:backgroundTint="@color/black"
                android:id="@+id/signinBtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_text"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#152EBA"
                android:id="@+id/signuptxt"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>