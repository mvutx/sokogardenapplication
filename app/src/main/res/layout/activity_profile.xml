<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#EAF2FF"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingBottom="60dp"
    tools:context=".MainActivity">

    <!-- App Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️ SokoGarden ❇️"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:background="#1E3A8A"
        android:padding="14dp"
        android:layout_marginBottom="10dp"/>

    <!-- 👋 Welcome User -->
    <TextView
        android:id="@+id/welcomeUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome 👋"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="#1E3A8A"
        android:layout_marginBottom="10dp"/>

    <!-- 📝 INFO TEXT (NEW ADDED) -->
    <TextView
        android:id="@+id/profileInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You can update your information below. Each section has its own save button."
        android:textSize="14sp"
        android:textColor="#374151"
        android:gravity="center"
        android:layout_marginBottom="15dp"/>

    <!-- ================= USERNAME ================= -->
    <EditText
        android:id="@+id/usernameEdit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Username"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/saveUsernameBtn"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="💾 Save Username"
        android:backgroundTint="#1E3A8A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- ================= EMAIL ================= -->
    <EditText
        android:id="@+id/emailEdit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Email"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/saveEmailBtn"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="💾 Save Email"
        android:backgroundTint="#10B981"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- ================= PASSWORD ================= -->
    <EditText
        android:id="@+id/passwordEdit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/savePasswordBtn"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="🔐 Save Password"
        android:backgroundTint="#EF4444"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- ================= PHONE ================= -->
    <EditText
        android:id="@+id/phoneEdit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Phone Number"
        android:inputType="phone"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/savePhoneBtn"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="📱 Save Phone"
        android:backgroundTint="#F59E0B"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="15dp"/>

    <!-- ================= BOTTOM NAV ================= -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#1E3A8A"
        app:itemTextColor="#1E3A8A"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>